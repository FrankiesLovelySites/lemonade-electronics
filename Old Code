<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lemonade Electronics | Corporate Hub</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        html { scroll-behavior: smooth; }
        .tech-card:hover { border-color: #facc15; background-color: #fafafa; transform: translateY(-2px); transition: all 0.3s ease; }
        .logo-img { max-height: 50px; width: auto; }
        /* Custom color override for specific Tailwind classes */
        .text-custom-blue { color: #0083c4; }
        .bg-custom-blue { background-color: #0083c4; }
        .border-custom-blue { border-color: #0083c4; }
    </style>
</head>
<body class="bg-white text-[#0083c4] font-sans">

    <nav class="border-b border-gray-100 py-6 px-8 flex justify-between items-center sticky top-0 bg-white/90 backdrop-blur-md z-50">
        <div class="flex items-center gap-3">
            <img src="https://i.ibb.co/qMv1zRmD/Screenshot-2026-04-13-014151.png" alt="Lemonade Logo" class="logo-img">
        </div>
        <div class="hidden md:flex gap-8 font-medium text-sm uppercase tracking-widest">
            <a href="#brands" class="hover:text-yellow-500 transition text-[#0083c4]">Our Brands</a>
            <a href="#tech" class="hover:text-yellow-500 transition text-[#0083c4]">Technology</a>
            <a href="#board" class="hover:text-yellow-500 transition text-[#0083c4]">Board</a>
            <a href="#contact" class="hover:text-yellow-500 transition border-b-2 border-yellow-400 text-[#0083c4]">Contact</a>
        </div>
    </nav>

    <header class="py-24 px-8 border-b border-gray-50">
        <div class="max-w-5xl mx-auto">
            <span class="bg-[#0083c4] text-yellow-400 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest">Corporate Site 🍋</span>
            <h1 class="text-6xl md:text-8xl font-black mt-6 mb-8 leading-tight text-[#0083c4]">
                Fresh Tech. <br>
                <span class="text-yellow-400 underline decoration-[#0083c4]">Zesty Solutions.</span>
            </h1>
            <p class="text-xl text-gray-500 max-w-2xl leading-relaxed">
                Lemonade Electronics is the central hub for cutting-edge hardware and software. We power a diverse portfolio of specialized companies under one ecosystem.
            </p>
        </div>
    </header>

    <section id="brands" class="py-20 px-8 bg-gray-50">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-3xl font-bold tracking-tight mb-12 text-[#0083c4]">Our Companies</h2>
            <div class="grid md:grid-cols-3 gap-8">
                
                <a href="https://core.lemon-electronics.fun" class="group block bg-white p-8 rounded-2xl border border-gray-200 transition-all duration-300 hover:-translate-y-2 hover:border-yellow-400 shadow-sm">
                    <div class="w-16 h-16 mb-6 flex items-center justify-center overflow-hidden">
                        <img src="https://i.ibb.co/twzhGjvP/Gemini-Generated-Image-5a2z645a2z645a2z-removebg-preview.png" alt="CORE Logo" class="w-full h-full object-contain">
                    </div>
                    <h3 class="text-2xl font-bold mb-2 uppercase tracking-tighter text-[#0083c4]">CORE</h3>
                    <p class="text-gray-500 mb-6 text-sm leading-relaxed">
                        Where code meets creativity. Our primary development hub focused on game design, proprietary engines, and interactive storytelling.
                    </p>
                    <span class="text-[#0083c4] font-bold flex items-center gap-2 text-sm uppercase tracking-wider">
                        Visit Studio <span class="group-hover:translate-x-2 transition-transform">→</span>
                    </span>
                </a>

                <div class="bg-white/50 p-8 rounded-2xl border border-dashed border-gray-300 flex items-center justify-center text-gray-400 font-bold uppercase tracking-widest text-xs">
                    New Subsidiary Coming Soon
                </div>

                <div class="bg-white/50 p-8 rounded-2xl border border-dashed border-gray-300 flex items-center justify-center text-gray-400 font-bold uppercase tracking-widest text-xs">
                    New Subsidiary Coming Soon
                </div>

            </div>
        </div>
    </section>

    <section id="tech" class="py-24 px-8 bg-white border-b border-gray-100">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-4xl font-black uppercase tracking-tighter text-[#0083c4]">The Lemonade <span class="text-yellow-500">stack</span></h2>
                <p class="text-gray-500 mt-4">We use industry-leading standards across all our electronics and software platforms.</p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="p-8 border border-gray-100 rounded-xl tech-card transition-all">
                    <p class="text-yellow-500 font-bold text-sm mb-2 uppercase">Software</p>
                    <h4 class="text-xl font-bold mb-3 text-[#0083c4]">Online Gaming Experiances</h4>
                    <p class="text-sm text-gray-600">High quality video-games for all people and needs.</p>
                </div>
                <div class="p-8 border border-gray-100 rounded-xl tech-card transition-all">
                    <p class="text-yellow-500 font-bold text-sm mb-2 uppercase">Customisable</p>
                    <h4 class="text-xl font-bold mb-3 text-[#0083c4]">Custom software, hardware, or video-games</h4>
                    <p class="text-sm text-gray-600">We create anything you can think of, with your full ownership.</p>
                </div>
                <div class="p-8 border border-gray-100 rounded-xl tech-card transition-all">
                    <p class="text-yellow-500 font-bold text-sm mb-2 uppercase">Service</p>
                    <h4 class="text-xl font-bold mb-3 text-[#0083c4]">3D Printing</h4>
                    <p class="text-sm text-gray-600">Custom, or premade 3D prints, straight to your door.</p>
                </div>
                <div class="p-8 border border-gray-100 rounded-xl tech-card transition-all">
                    <p class="text-yellow-500 font-bold text-sm mb-2 uppercase">And...</p>
                    <h4 class="text-xl font-bold mb-3 text-[#0083c4]">So Much More!</h4>
                    <p class="text-sm text-gray-600">Contact us to find out more about us.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="board" class="py-24 px-8 bg-white">
        <div class="max-w-6xl mx-auto">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-4">
                <div>
                    <h2 class="text-4xl font-black uppercase tracking-tighter text-[#0083c4]">Board of <span class="text-yellow-500">Directors</span></h2>
                    <p class="text-gray-500 mt-2">The visionaries steering the Lemonade ecosystem.</p>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
                <div class="group">
                    <div class="aspect-square bg-gray-100 rounded-2xl mb-6 overflow-hidden border-b-4 border-transparent group-hover:border-yellow-400 transition-all">
                        <img src="https://i.ibb.co/zTmzGFvc/rent-laser-light-show-miami-flexible-professional-rentals4.jpg" alt="Director" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500">
                    </div>
                    <h3 class="text-2xl font-bold text-[#0083c4]">Frankie S</h3>
                    <p class="text-yellow-500 font-bold text-xs uppercase tracking-widest mt-1">Chief Executive Officer</p>
                    <p class="text-gray-500 text-sm mt-4 leading-relaxed">"Tech should be refreshing. We’re here to provide the zest."</p>
                </div>

                <div class="group">
                    <div class="aspect-square bg-gray-100 rounded-2xl mb-6 overflow-hidden border-b-4 border-transparent group-hover:border-yellow-400 transition-all">
                        <img src="https://i.ibb.co/B2BY7JyS/Moon.jpg" alt="Director" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500">
                    </div>
                    <h3 class="text-2xl font-bold text-[#0083c4]">Sam J</h3>
                    <p class="text-yellow-500 font-bold text-xs uppercase tracking-widest mt-1">Co-Chief Operations Officer</p>
                    <p class="text-gray-500 text-sm mt-4 leading-relaxed">"Keep going, 'cause you never know when things will get better."</p>
                </div>

                <div class="group">
                    <div class="aspect-square bg-gray-100 rounded-2xl mb-6 overflow-hidden border-b-4 border-transparent group-hover:border-yellow-400 transition-all">
                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Director3" alt="Director" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500">
                    </div>
                    <h3 class="text-2xl font-bold text-[#0083c4]">Executive Position</h3>
                    <p class="text-yellow-500 font-bold text-xs uppercase tracking-widest mt-1">Co-Chief Operations Officer</p>
                    <p class="text-gray-500 text-sm mt-4 leading-relaxed">Overseeing the "Lemonade Stack" and proprietary engine development at CORE.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="py-24 px-8 bg-gray-50">
        <div class="max-w-4xl mx-auto bg-[#0083c4] text-white rounded-3xl p-12 relative overflow-hidden">
            <div class="absolute -top-10 -right-10 w-40 h-40 bg-yellow-400 rounded-full opacity-20"></div>
            <div class="relative z-10">
                <h2 class="text-4xl font-black mb-4 uppercase tracking-tighter">Get in Touch</h2>
                <p class="text-gray-100 mb-10 text-lg opacity-80">Direct lines to the Lemonade Electronics team.</p>
                <div class="grid md:grid-cols-2 gap-8 text-[#0083c4]">
                    <div class="flex items-center gap-4 p-6 bg-white rounded-xl">
                        <div>
                            <p class="text-xs uppercase tracking-widest text-gray-400 font-bold">Whatsapp</p>
                            <a href="tel:07934906658" class="text-xl font-black hover:text-yellow-500 transition">+44 7934906658</a>
                        </div>
                    </div>
                    <div class="flex items-center gap-4 p-6 bg-white rounded-xl">
                        <div>
                            <p class="text-xs uppercase tracking-widest text-gray-400 font-bold">Discord</p>
                            <p class="text-xl font-black tracking-tight uppercase">lemonade_dev</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-white text-[#0083c4] py-16 px-8 border-t border-gray-100 flex flex-col items-center gap-6">
        <img src="https://i.ibb.co/qMv1zRmD/Screenshot-2026-04-13-014151.png" alt="Lemonade Logo" class="h-12 w-auto">
        <div class="text-center">
            <p class="text-gray-500 text-xs mt-1 uppercase tracking-widest font-bold">
                &copy; 2023-26 Lemonade Electronics // All Rights Reserved
            </p>
        </div>
    </footer>

</body>
</html>
